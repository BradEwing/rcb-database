---
import Layout from '../layouts/Layout.astro';
import MapView from '../components/MapView.astro';
---

<Layout>
  <header class="topbar">
    <div class="brand">
      <span class="kicker">Santa Monica</span>
      <h1>Rent-Control Registry</h1>
    </div>
    <p class="tagline">Maximum Allowable Rent by parcel · hover a parcel for its unit breakdown</p>
  </header>

  <main class="map-page">
    <MapView />
  </main>
</Layout>

<style>
  .map-page {
    position: fixed;
    inset: 0;
  }

  .topbar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 3;
    display: flex;
    align-items: baseline;
    gap: 1rem 1.25rem;
    flex-wrap: wrap;
    padding: 0.7rem 1rem;
    background: color-mix(in srgb, var(--bg) 90%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid color-mix(in srgb, var(--muted) 30%, transparent);
  }
  .brand {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .kicker {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--muted);
  }
  h1 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
  }
  .tagline {
    margin: 0;
    font-size: 0.82rem;
    color: var(--muted);
  }
</style>
