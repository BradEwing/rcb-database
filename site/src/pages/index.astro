---
import Layout from '../layouts/Layout.astro';
import MapView from '../components/MapView.astro';
---

<Layout>
  <header class="topbar">
    <div class="brand">
      <span class="kicker">Santa Monica</span>
      <h1>Rent-Control Registry</h1>
    </div>
    <p class="tagline">Maximum Allowable Rent by parcel · click a parcel for its unit breakdown</p>
    <div class="search" role="search">
      <input
        id="parcel-search"
        type="search"
        placeholder="Search address or APN…"
        autocomplete="off"
        aria-label="Search by address or APN"
      />
      <ul id="search-results" class="search-results" hidden></ul>
    </div>
    <dl id="summary-stats" class="stats" aria-label="Citywide totals"></dl>
    <nav class="nav">
      <a href={`${import.meta.env.BASE_URL}/charts/`}>Charts</a>
      <a href={`${import.meta.env.BASE_URL}/about/`}>About</a>
    </nav>
  </header>

  <main class="map-page">
    <MapView />
  </main>
</Layout>

<script>
  import { dataUrl } from '../config';
  import { formatCount } from '../lib/format';
  import type { SiteSummary } from '../lib/types';

  // Publish the topbar's real height as --topbar-h so the map controls anchor
  // below it even when it wraps to two rows (≤~1400px) or grows when the
  // summary stats load — a fixed offset left the metric switch underneath the
  // (higher z-index) bar, swallowing its clicks.
  const topbar = document.querySelector<HTMLElement>('.topbar');
  if (topbar) {
    const setTopbarHeight = (): void => {
      document.documentElement.style.setProperty('--topbar-h', `${topbar.offsetHeight}px`);
    };
    new ResizeObserver(setTopbarHeight).observe(topbar);
    setTopbarHeight();
  }

  const el = document.getElementById('summary-stats');
  if (el) {
    fetch(dataUrl('summary.json'))
      .then((r) => (r.ok ? (r.json() as Promise<SiteSummary>) : Promise.reject(r.status)))
      .then((s) => {
        const stats: Array<[string, string]> = [
          [formatCount(s.controlled_total), 'controlled units'],
          [formatCount(s.units_total), 'with a MAR'],
          [formatCount(s.rcb_comparable ?? 0), 'RCB-comparable'],
          [s.latest_sweep, 'last sweep'],
        ];
        el.innerHTML = stats
          .map(([v, k]) => `<div><dt>${v}</dt><dd>${k}</dd></div>`)
          .join('');
      })
      .catch(() => {
        /* header stats are non-essential; leave empty on failure */
      });
  }
</script>

<style>
  .map-page {
    position: fixed;
    inset: 0;
  }

  .topbar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 3;
    display: flex;
    align-items: baseline;
    gap: 1rem 1.25rem;
    flex-wrap: wrap;
    padding: 0.7rem 1rem;
    background: color-mix(in srgb, var(--bg) 90%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid color-mix(in srgb, var(--muted) 30%, transparent);
  }
  .brand {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .kicker {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--muted);
  }
  h1 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
  }
  .tagline {
    margin: 0;
    font-size: 0.82rem;
    color: var(--muted);
  }

  .search {
    position: relative;
    flex: 1 1 200px;
    max-width: 320px;
  }
  .search input {
    width: 100%;
    padding: 0.4rem 0.6rem;
    font-size: 0.85rem;
    border-radius: 0.45rem;
    border: 1px solid color-mix(in srgb, var(--muted) 40%, transparent);
    background: var(--bg);
    color: var(--fg);
  }
  .search-results {
    position: absolute;
    top: calc(100% + 0.25rem);
    left: 0;
    right: 0;
    z-index: 5;
    margin: 0;
    padding: 0.25rem;
    list-style: none;
    background: var(--bg);
    border: 1px solid color-mix(in srgb, var(--muted) 35%, transparent);
    border-radius: 0.45rem;
    box-shadow: 0 6px 18px rgb(0 0 0 / 0.16);
    max-height: 60vh;
    overflow-y: auto;
  }
  .search-results[hidden] {
    display: none;
  }
  .search-results :global(button) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    width: 100%;
    border: none;
    background: none;
    color: var(--fg);
    text-align: left;
    padding: 0.4rem 0.5rem;
    border-radius: 0.3rem;
    font-size: 0.82rem;
    cursor: pointer;
  }
  .search-results :global(button:hover) {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }
  .search-results :global(.r-apn) {
    color: var(--muted);
    font-size: 0.7rem;
    font-variant-numeric: tabular-nums;
  }

  .nav {
    display: flex;
    gap: 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .nav a {
    color: var(--accent);
    text-decoration: none;
  }

  .stats {
    display: flex;
    gap: 1.1rem;
    margin: 0;
    margin-left: auto;
  }
  .stats :global(div) {
    text-align: right;
    line-height: 1.1;
  }
  .stats :global(dt) {
    font-weight: 700;
    font-size: 0.95rem;
    font-variant-numeric: tabular-nums;
  }
  .stats :global(dd) {
    margin: 0;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  @media (max-width: 640px) {
    .stats {
      display: none;
    }
  }
</style>
