---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Charts — Santa Monica Rent-Control Registry">
  <article class="charts">
    <p class="back"><a href={`${base}/`}>← Back to the map</a></p>

    <h1>Rent by the numbers</h1>
    <p class="lede">Citywide breakdowns of Santa Monica's rent-controlled stock.</p>

    <ul class="notes" aria-label="About these figures">
      <li><strong>Controlled units only</strong> — exempt ($0&nbsp;MAR) units excluded.</li>
      <li><strong>History to 2012</strong> — back-filled from annual Rent Control filings; live scrapes began June 2026.</li>
      <li><strong>All figures are medians</strong> — bands span the 25th–75th percentile.</li>
    </ul>

    <section class="chart-block">
      <h2>Median MAR by bedroom, over time</h2>
      <p class="chart-note">
        Median allowed rent as of each month, reconstructed from the change log.
        3+&nbsp;BR is omitted pending an anomaly investigation
        (<a href="https://github.com/BradEwing/rcb-database/issues/11">issue #11</a>).
      </p>
      <figure id="rent-over-time" class="chart"><p class="loading">Loading chart…</p></figure>
    </section>

    <section class="chart-block">
      <h2>Current median by bedroom count</h2>
      <dl id="rent-by-bedroom-table" class="chart-table" aria-label="Median MAR by bedroom count"></dl>
    </section>

    <section class="chart-block">
      <h2>New-tenancy rents over time</h2>
      <p class="chart-note">
        <span id="new-tenancy-note"></span>
      </p>
      <figure id="new-tenancy-rent" class="chart"><p class="loading">Loading chart…</p></figure>
    </section>

    <section class="chart-block">
      <h2>MAR vs Tenancy Start Date</h2>
      <p class="chart-note">
        Each line tracks the maximum rent of a tenancy today against the month it
        began, smoothed over a ~15-month window.
        Click a bedroom type to show or hide it.
        <span id="vintage-note"></span>
      </p>
      <figure id="mar-by-vintage" class="chart"><p class="loading">Loading chart…</p></figure>
    </section>

    <p class="more"><a href={`${base}/about/`}>About this registry →</a></p>

    <footer id="provenance" class="provenance">Loading build provenance…</footer>
  </article>
</Layout>

<script>
  import { dataUrl } from '../config';
  import { marByTenancyVintageChart, newTenancyRentChart, rentOverTimeChart } from '../lib/chart';
  import { formatMarCents, formatCount } from '../lib/format';
  import type { SiteAnalytics, SiteMeta } from '../lib/types';

  const timeHost = document.getElementById('rent-over-time');
  const vintageHost = document.getElementById('mar-by-vintage');
  const newTenancyHost = document.getElementById('new-tenancy-rent');
  const tableEl = document.getElementById('rent-by-bedroom-table');
  let analytics: SiteAnalytics | null = null;

  function renderChart(): void {
    if (!analytics) return;
    if (timeHost) {
      timeHost.replaceChildren(
        rentOverTimeChart(analytics.rent_over_time.series, timeHost.clientWidth || 640),
      );
    }
    if (vintageHost) {
      vintageHost.replaceChildren(
        marByTenancyVintageChart(
          analytics.mar_by_tenancy_vintage,
          vintageHost.clientWidth || 640,
        ),
      );
    }
    // Guarded: a cached pre-deploy analytics.json (Pages caches data for ~10
    // min) can lack this key right after a deploy — degrade to the unavailable
    // message instead of throwing and blanking every chart via the fetch catch.
    if (newTenancyHost) {
      if (analytics.new_tenancy_rent) {
        newTenancyHost.replaceChildren(
          newTenancyRentChart(analytics.new_tenancy_rent, newTenancyHost.clientWidth || 640),
        );
      } else {
        newTenancyHost.innerHTML = '<p class="loading">Chart data unavailable.</p>';
      }
    }
  }

  fetch(dataUrl('analytics.json'))
    .then((r) => (r.ok ? (r.json() as Promise<SiteAnalytics>) : Promise.reject(r.status)))
    .then((a) => {
      analytics = a;
      renderChart();
      const v = a.mar_by_tenancy_vintage;
      const noteEl = document.getElementById('vintage-note');
      if (v && noteEl) {
        const threeBr = v.buckets.find((b) => b.bucket === '3+')?.count ?? 0;
        const shownUnits = v.total_points - threeBr;
        noteEl.textContent =
          `${formatCount(shownUnits)} units; excluded: ` +
          `${formatCount(v.excluded_empty_tenancy)} with no reset date, ` +
          `${formatCount(threeBr)} 3+ BR.`;
      }
      const nt = a.new_tenancy_rent;
      const ntNoteEl = document.getElementById('new-tenancy-note');
      if (nt && ntNoteEl) {
        const ntThreeBr = nt.buckets.find((b) => b.bucket === '3+')?.count ?? 0;
        ntNoteEl.textContent =
          `${formatCount(nt.total_events - ntThreeBr)} tenancy starts; ` +
          `${formatCount(nt.excluded_ga_lag)} excluded as first observed ` +
          `only after a general adjustment.`;
      }
      if (tableEl) {
        tableEl.innerHTML = a.rent_by_bedroom
          .map(
            (r) =>
              `<div><dt>${r.label}</dt><dd>${formatMarCents(r.median_cents)} median` +
              ` · ${formatCount(r.count)} units</dd></div>`,
          )
          .join('');
      }
    })
    .catch(() => {
      const msg = '<p class="loading">Chart data unavailable.</p>';
      if (timeHost) timeHost.innerHTML = msg;
      if (vintageHost) vintageHost.innerHTML = msg;
      if (newTenancyHost) newTenancyHost.innerHTML = msg;
      if (tableEl) tableEl.innerHTML = msg;
    });

  // Re-render on resize (debounced) so the SVG tracks the container width.
  let resizeTimer: number | undefined;
  window.addEventListener('resize', () => {
    window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(renderChart, 150);
  });

  const prov = document.getElementById('provenance');
  if (prov) {
    fetch(dataUrl('meta.json'))
      .then((r) => (r.ok ? (r.json() as Promise<SiteMeta>) : Promise.reject(r.status)))
      .then((m) => {
        const built = new Date(m.built_at).toISOString().slice(0, 10);
        prov.textContent =
          `Latest sweep ${m.latest_sweep} · built ${built} · ` +
          `${m.units_total.toLocaleString()} units tracked (positive-MAR + $0/exempt).`;
      })
      .catch(() => {
        prov.textContent = '';
      });
  }
</script>

<style>
  .charts {
    max-width: 44rem;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 4rem;
  }
  .back {
    font-size: 0.85rem;
  }
  .back a,
  .more a {
    color: var(--accent);
    text-decoration: none;
  }
  h1 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    margin: 0.4rem 0 0.6rem;
  }
  .lede {
    font-size: 1.05rem;
    margin-bottom: 0.75rem;
  }
  .notes {
    list-style: none;
    margin: 0;
    padding: 0.75rem 1rem;
    border: 1px solid color-mix(in srgb, var(--muted) 30%, transparent);
    border-radius: 6px;
    font-size: 0.82rem;
    color: var(--muted);
  }
  .notes li {
    padding: 0.1rem 0;
  }
  .chart-block {
    margin-top: 2.25rem;
  }
  h2 {
    font-size: 1.15rem;
    margin: 0 0 0.35rem;
  }
  .chart-note {
    margin: 0 0 1rem;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .chart-note a {
    color: var(--accent);
  }
  .chart {
    margin: 0;
    min-height: 200px;
  }
  .chart :global(svg) {
    max-width: 100%;
    height: auto;
  }
  .chart :global(.plot-legend) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1.1rem;
    margin: 0 0 0.6rem;
    font-size: 0.78rem;
    color: var(--muted);
  }
  .chart :global(.plot-legend .lk) {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .chart :global(.plot-legend .sw) {
    display: inline-block;
    flex: none;
  }
  .chart :global(.plot-legend button.plot-toggle) {
    font: inherit;
    color: inherit;
    background: none;
    border: 1px solid color-mix(in srgb, var(--muted) 35%, transparent);
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
    cursor: pointer;
  }
  .chart :global(.plot-legend button.plot-toggle[aria-pressed='false']) {
    border-style: dashed;
  }
  .loading {
    color: var(--muted);
    font-size: 0.9rem;
  }
  .chart-table {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.4rem;
    margin: 0.75rem 0 0;
    font-size: 0.82rem;
  }
  .chart-table :global(div) {
    display: flex;
    gap: 0.4rem;
    align-items: baseline;
  }
  .chart-table :global(dt) {
    font-weight: 700;
  }
  .chart-table :global(dd) {
    margin: 0;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .more {
    margin-top: 2.5rem;
    font-weight: 600;
  }
  .provenance {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--muted) 30%, transparent);
    font-size: 0.78rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
</style>
