---
import 'maplibre-gl/dist/maplibre-gl.css';
---

<div id="map" role="application" aria-label="Map of Santa Monica rent-controlled parcels"></div>

<div id="metric-switch" class="metric-switch" role="group" aria-label="Choropleth metric"></div>

<div class="legend">
  <p id="legend-title" class="legend-title"></p>
  <div id="range-picker" class="range-picker" hidden>
    <label>From <select id="range-from" aria-label="Baseline year"></select></label>
    <span class="rp-arrow">→</span>
    <label>to <select id="range-to" aria-label="End year"></select></label>
  </div>
  <ul id="legend-body"></ul>
  <p id="legend-note" class="legend-note"></p>
  <div id="map-toggles" class="map-toggles" hidden>
    <label id="d3-toggle" class="map-toggle" hidden>
      <input type="checkbox" id="d3-checkbox" />
      3D buildings
    </label>
    <div id="height-mult" class="height-mult" hidden>
      <span class="hm-label">Height ∝ controlled units</span>
      <div id="hm-buttons" class="hm-buttons" role="group" aria-label="Height multiplier"></div>
    </div>
    <label id="boundary-toggle" class="map-toggle" hidden>
      <input type="checkbox" id="boundary-checkbox" checked />
      City limits
    </label>
    <label id="place-toggle" class="map-toggle" hidden>
      <input type="checkbox" id="place-label-checkbox" />
      Place labels
    </label>
  </div>
</div>

<aside id="detail-panel" class="detail-panel" aria-label="Parcel detail" hidden>
  <button id="detail-close" class="detail-close" type="button" aria-label="Close parcel detail">
    ✕
  </button>
  <div id="detail-body" class="detail-body"></div>
</aside>

<script>
  import maplibregl from 'maplibre-gl';
  import {
    BASEMAP_STYLE,
    INITIAL_CENTER,
    INITIAL_ZOOM,
    PARCEL_ATTRIBUTION,
    METRICS,
    colorExpressionFor,
    recentChangeColorExpression,
    changeStops,
    changeLegend,
    RECENT_CHANGE_COLORS,
    NO_DATA_COLOR,
    USE_TYPE_GROUPS,
    useTypeFilterExpression,
    type UseTypeGroupKey,
    RECENT_CHANGE_DEFAULT_BASELINE,
    dataUrl,
    BOUNDARY_LINE_COLOR,
    BOUNDARY_LINE_WIDTH,
    BOUNDARY_MASK_COLOR,
    BOUNDARY_MASK_OPACITY,
    EXTRUSION_PITCH,
    EXTRUSION_MULTIPLIERS,
    EXTRUSION_DEFAULT_MULTIPLIER,
    EXTRUSION_OPACITY,
    extrusionHeightExpression,
    type MetricKey,
  } from '../config';
  import { formatCount, formatMarCents, formatPct, useClassLabel } from '../lib/format';
  import { renderParcelDetail } from '../lib/detail';
  import type { ParcelProperties, ParcelDetail, MarByYear } from '../lib/types';

  let activeMetric: MetricKey = 'unit_count';

  // ---- Configurable MAR-change choropleth state -----------------------------
  // The loaded parcels GeoJSON (kept so we can rewrite per-feature change % and
  // push it back with setData when the year range changes), the per-parcel
  // median-MAR-by-year matrix, and the currently selected comparison window.
  let parcelsGeojson: GeoJSON.FeatureCollection | null = null;
  let marByYear: MarByYear | null = null;
  let marByYearPromise: Promise<void> | null = null;
  let baselineYear = 0;
  let endYear = 0;

  const map = new maplibregl.Map({
    container: 'map',
    style: BASEMAP_STYLE,
    center: INITIAL_CENTER,
    zoom: INITIAL_ZOOM,
    attributionControl: false,
  });
  // Compass shown so users can reset bearing/pitch after orbiting in 3D mode.
  map.addControl(new maplibregl.NavigationControl({ showCompass: true, visualizePitch: true }), 'top-right');
  map.addControl(
    new maplibregl.AttributionControl({ compact: false, customAttribution: PARCEL_ATTRIBUTION }),
    'bottom-right',
  );

  const escapeHtml = (s: string): string =>
    s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]!);

  function tooltipHtml(p: ParcelProperties): string {
    const controlled = `${formatCount(p.controlled_count)} controlled`;
    const exempt = p.exempt_count > 0 ? ` · ${formatCount(p.exempt_count)} exempt` : '';
    const use =
      activeMetric === 'use_type'
        ? `<span class="row">Use: ${escapeHtml(useClassLabel(p.use_class))} (County assessor)</span>`
        : '';
    let change = '';
    if (activeMetric === 'recent_change' && marByYear) {
      change = p.range_has_data
        ? `<span class="row">MAR change ${baselineYear}→${endYear}: ${formatPct(p.range_change_pct ?? 0)} (median unit)</span>`
        : `<span class="row">No unit controlled in both ${baselineYear} &amp; ${endYear}</span>`;
    } else if (p.recent_change_count > 0) {
      change = `<span class="row">Recent change ${formatPct(p.recent_change_pct)} · ${formatCount(p.recent_change_count)} unit(s)</span>`;
    }
    return (
      `<strong>${escapeHtml(p.label_address)}</strong>` +
      `<span class="apn">APN ${escapeHtml(p.apn)}</span>` +
      `<span class="row">${formatCount(p.unit_count)} units — ${controlled}${exempt}</span>` +
      `<span class="row">Median MAR ${formatMarCents(p.median_mar_cents)}</span>` +
      use +
      change
    );
  }

  // Extend a bounds object with every coordinate in a (Multi)Polygon geometry.
  function extendBounds(b: maplibregl.LngLatBounds, geom: GeoJSON.Geometry): void {
    if (geom.type === 'Polygon') {
      for (const ring of geom.coordinates)
        for (const c of ring) b.extend(c as [number, number]);
    } else if (geom.type === 'MultiPolygon') {
      for (const poly of geom.coordinates)
        for (const ring of poly) for (const c of ring) b.extend(c as [number, number]);
    }
  }

  // Build a "dim everything outside the city" mask: one polygon covering the
  // world with each city-boundary outer ring punched out as a hole. Filling it
  // shades the world minus Santa Monica.
  function maskOutside(boundary: GeoJSON.FeatureCollection): GeoJSON.Feature {
    const world: GeoJSON.Position[] = [
      [-180, -85],
      [180, -85],
      [180, 85],
      [-180, 85],
      [-180, -85],
    ];
    const holes: GeoJSON.Position[][] = [];
    for (const f of boundary.features) {
      const geom = f.geometry;
      if (!geom) continue;
      if (geom.type === 'Polygon') holes.push(geom.coordinates[0]!);
      else if (geom.type === 'MultiPolygon')
        for (const poly of geom.coordinates) holes.push(poly[0]!);
    }
    return {
      type: 'Feature',
      properties: {},
      geometry: { type: 'Polygon', coordinates: [world, ...holes] },
    };
  }

  // Reveal the legend's map-settings group (hidden until something populates it).
  function revealToggles(): void {
    const group = document.getElementById('map-toggles');
    if (group) group.hidden = false;
  }

  // Reveal the legend's city-limits toggle (hidden until the overlay loads) and
  // wire it to both boundary layers' visibility.
  function initBoundaryToggle(): void {
    const toggle = document.getElementById('boundary-toggle') as HTMLElement | null;
    const checkbox = document.getElementById('boundary-checkbox') as HTMLInputElement | null;
    if (!toggle || !checkbox) return;
    revealToggles();
    toggle.hidden = false;
    checkbox.addEventListener('change', () => {
      const visibility = checkbox.checked ? 'visible' : 'none';
      for (const id of ['city-mask-fill', 'city-boundary-line']) {
        if (map.getLayer(id)) map.setLayoutProperty(id, 'visibility', visibility);
      }
    });
  }

  // Basemap place names (city + neighborhood labels) live in the vector tiles'
  // `place` source-layer; hide them as a group to declutter the map. Matches by
  // source-layer (robust) with an id-prefix fallback for style variants.
  function placeLabelLayerIds(): string[] {
    const style = map.getStyle();
    return (style.layers ?? [])
      .filter(
        (l) =>
          l.type === 'symbol' &&
          ((l as { 'source-layer'?: string })['source-layer'] === 'place' ||
            /^place[_-]/.test(l.id)),
      )
      .map((l) => l.id);
  }
  function setPlaceLabels(visible: boolean): void {
    for (const id of placeLabelLayerIds()) {
      if (map.getLayer(id)) {
        map.setLayoutProperty(id, 'visibility', visible ? 'visible' : 'none');
      }
    }
  }

  // Reveal the place-labels toggle and wire it. Default OFF (labels hidden) — the
  // dimmed surroundings read cleaner without city/neighborhood names.
  function initPlaceLabelsToggle(): void {
    const toggle = document.getElementById('place-toggle') as HTMLElement | null;
    const checkbox = document.getElementById('place-label-checkbox') as HTMLInputElement | null;
    if (!toggle || !checkbox) return;
    setPlaceLabels(false);
    checkbox.checked = false;
    revealToggles();
    toggle.hidden = false;
    checkbox.addEventListener('change', () => setPlaceLabels(checkbox.checked));
  }

  // ---- 3D extrusion mode ----------------------------------------------------
  // A VoteHub-style read of the controlled stock: parcels extruded by their
  // controlled-unit count, coloured by the active metric, viewed pitched. OFF by
  // default. `heightMultiplier` is the user's 1×–50× choice (the metric switcher
  // recolours both the flat fill and the extrusion unconditionally).
  let heightMultiplier: number = EXTRUSION_DEFAULT_MULTIPLIER;

  function applyExtrusionHeight(): void {
    if (map.getLayer('parcels-3d')) {
      map.setPaintProperty('parcels-3d', 'fill-extrusion-height', extrusionHeightExpression(heightMultiplier));
    }
  }

  // Render the 1×/5×/…/50× segmented control and wire each preset.
  function renderHeightButtons(): void {
    const host = document.getElementById('hm-buttons');
    if (!host) return;
    host.innerHTML = EXTRUSION_MULTIPLIERS.map(
      (m) =>
        `<button type="button" data-mult="${m}" class="${m === heightMultiplier ? 'active' : ''}" ` +
        `aria-pressed="${m === heightMultiplier}">${m}×</button>`,
    ).join('');
    host.querySelectorAll('button').forEach((btn) =>
      btn.addEventListener('click', () => {
        heightMultiplier = Number(btn.dataset.mult);
        renderHeightButtons();
        applyExtrusionHeight();
      }),
    );
  }

  // Flip the whole map between flat choropleth and pitched 3D skyline.
  function set3D(on: boolean): void {
    const heightMult = document.getElementById('height-mult');
    if (heightMult) heightMult.hidden = !on;
    // Swap which parcel layer is visible (extrusion vs flat fill+outline).
    if (map.getLayer('parcels-3d'))
      map.setLayoutProperty('parcels-3d', 'visibility', on ? 'visible' : 'none');
    for (const id of ['parcels-fill', 'parcels-line']) {
      if (map.getLayer(id)) map.setLayoutProperty(id, 'visibility', on ? 'none' : 'visible');
    }
    map.easeTo({ pitch: on ? EXTRUSION_PITCH : 0, duration: 600 });
  }

  // Reveal + wire the 3D toggle (hidden until the extrusion layer is added).
  function init3DToggle(): void {
    const toggle = document.getElementById('d3-toggle') as HTMLElement | null;
    const checkbox = document.getElementById('d3-checkbox') as HTMLInputElement | null;
    if (!toggle || !checkbox || !map.getLayer('parcels-3d')) return;
    revealToggles();
    toggle.hidden = false;
    checkbox.checked = false;
    renderHeightButtons();
    checkbox.addEventListener('change', () => set3D(checkbox.checked));
  }

  map.on('load', async () => {
    const res = await fetch(dataUrl('parcels.geojson'));
    if (!res.ok) throw new Error(`Failed to load parcels.geojson: ${res.status}`);
    const geojson = (await res.json()) as GeoJSON.FeatureCollection;
    parcelsGeojson = geojson;

    map.addSource('parcels', { type: 'geojson', data: geojson, promoteId: 'apn' });

    map.addLayer({
      id: 'parcels-fill',
      type: 'fill',
      source: 'parcels',
      paint: {
        'fill-color': colorExpressionFor(activeMetric),
        'fill-opacity': ['case', ['boolean', ['feature-state', 'hover'], false], 0.95, 0.72],
      },
    });
    map.addLayer({
      id: 'parcels-line',
      type: 'line',
      source: 'parcels',
      paint: {
        'line-color': [
          'case',
          ['boolean', ['feature-state', 'selected'], false],
          '#b91c1c',
          '#2b3b4e',
        ],
        'line-width': [
          'case',
          ['boolean', ['feature-state', 'selected'], false],
          2.6,
          ['boolean', ['feature-state', 'hover'], false],
          1.8,
          0.3,
        ],
        'line-opacity': 0.6,
      },
    });

    // 3D extrusion layer — the controlled stock as a skyline, height ∝
    // controlled-unit count, coloured by the active metric. Shares the parcels
    // source; hidden until the "3D buildings" toggle pitches the camera.
    map.addLayer({
      id: 'parcels-3d',
      type: 'fill-extrusion',
      source: 'parcels',
      layout: { visibility: 'none' },
      paint: {
        'fill-extrusion-color': colorExpressionFor(activeMetric),
        'fill-extrusion-height': extrusionHeightExpression(heightMultiplier),
        'fill-extrusion-base': 0,
        'fill-extrusion-opacity': EXTRUSION_OPACITY,
      },
    });
    init3DToggle();

    // City-limits overlay — a soft dim outside the boundary (mask under the
    // parcels so they stay vivid) plus a crisp outline on top. Optional: if the
    // boundary artifact is absent the toggle simply stays hidden.
    try {
      const boundaryRes = await fetch(dataUrl('city-boundary.geojson'));
      if (boundaryRes.ok) {
        const boundary = (await boundaryRes.json()) as GeoJSON.FeatureCollection;
        map.addSource('city-mask', { type: 'geojson', data: maskOutside(boundary) });
        map.addSource('city-boundary', { type: 'geojson', data: boundary });
        // Mask below the parcels; outline above them (city edge stays legible).
        map.addLayer(
          {
            id: 'city-mask-fill',
            type: 'fill',
            source: 'city-mask',
            paint: { 'fill-color': BOUNDARY_MASK_COLOR, 'fill-opacity': BOUNDARY_MASK_OPACITY },
          },
          'parcels-fill',
        );
        map.addLayer({
          id: 'city-boundary-line',
          type: 'line',
          source: 'city-boundary',
          paint: {
            'line-color': BOUNDARY_LINE_COLOR,
            'line-width': BOUNDARY_LINE_WIDTH,
            'line-opacity': 0.85,
          },
        });
        initBoundaryToggle();
      }
    } catch {
      /* city-limits overlay is optional */
    }

    // Frame the data + index features by APN for deep-link fly-to.
    const bounds = new maplibregl.LngLatBounds();
    for (const f of geojson.features) {
      if (!f.geometry) continue;
      extendBounds(bounds, f.geometry);
      const apn = (f.properties as ParcelProperties | null)?.apn;
      if (apn) featureByApn.set(String(apn), f);
    }
    if (!bounds.isEmpty()) map.fitBounds(bounds, { padding: 24, animate: false });

    // Exit markers — units gone from the latest sweep (empty at the seed).
    try {
      const exitsRes = await fetch(dataUrl('exits.geojson'));
      if (exitsRes.ok) {
        map.addSource('exits', { type: 'geojson', data: await exitsRes.json() });
        map.addLayer({
          id: 'exits',
          type: 'circle',
          source: 'exits',
          paint: {
            'circle-radius': 5,
            'circle-color': '#dc2626',
            'circle-stroke-color': '#fff',
            'circle-stroke-width': 1.5,
            'circle-opacity': 0.9,
          },
        });
        map.on('click', 'exits', (e) => {
          const apn = (e.features?.[0]?.properties as { apn?: string } | undefined)?.apn;
          if (apn) void openParcel(apn);
        });
        map.on('mouseenter', 'exits', () => (map.getCanvas().style.cursor = 'pointer'));
        map.on('mouseleave', 'exits', () => (map.getCanvas().style.cursor = ''));
      }
    } catch {
      /* exits layer is optional */
    }

    renderSwitch();
    renderLegend();
    initPlaceLabelsToggle();

    // Hover: highlight via feature-state + a follow-the-cursor tooltip.
    const popup = new maplibregl.Popup({
      closeButton: false,
      closeOnClick: false,
      className: 'parcel-tip',
      maxWidth: '260px',
    });
    let hovered: string | null = null;

    // The flat fill and the 3D extrusion are mutually exclusive (the toggle hides
    // one), so the same hover/click logic binds to both parcel layers.
    for (const layerId of ['parcels-fill', 'parcels-3d']) {
      map.on('mousemove', layerId, (e) => {
        const f = e.features?.[0];
        if (!f) return;
        map.getCanvas().style.cursor = 'pointer';
        const id = String(f.id);
        if (hovered !== id) {
          if (hovered) map.setFeatureState({ source: 'parcels', id: hovered }, { hover: false });
          hovered = id;
          map.setFeatureState({ source: 'parcels', id }, { hover: true });
        }
        popup.setLngLat(e.lngLat).setHTML(tooltipHtml(f.properties as ParcelProperties)).addTo(map);
      });
      map.on('mouseleave', layerId, () => {
        map.getCanvas().style.cursor = '';
        if (hovered) map.setFeatureState({ source: 'parcels', id: hovered }, { hover: false });
        hovered = null;
        popup.remove();
      });
      // Click: lazy-load the per-APN detail and open the side panel.
      map.on('click', layerId, (e) => {
        const f = e.features?.[0];
        if (!f) return;
        void openParcel(String(f.id));
      });
    }

    // Deep link: open + fly to a parcel named in the URL hash (#apn=...).
    const initial = apnFromHash();
    if (initial && featureByApn.has(initial)) {
      flyToParcel(initial);
      void openParcel(initial);
    }
  });

  // ---- Detail panel ---------------------------------------------------------
  const panel = document.getElementById('detail-panel') as HTMLElement;
  const panelBody = document.getElementById('detail-body') as HTMLElement;
  const closeBtn = document.getElementById('detail-close') as HTMLButtonElement;
  let selected: string | null = null;
  const detailCache = new Map<string, ParcelDetail>();
  const featureByApn = new Map<string, GeoJSON.Feature>();

  // ---- Deep link (#apn=...) -------------------------------------------------
  function apnFromHash(): string | null {
    const m = /(?:^|[#&])apn=(\d+)/.exec(location.hash);
    return m ? m[1]! : null;
  }
  function setHash(apn: string): void {
    history.replaceState(null, '', `#apn=${apn}`);
  }
  function clearHash(): void {
    history.replaceState(null, '', location.pathname + location.search);
  }

  function flyToParcel(apn: string): void {
    const f = featureByApn.get(apn);
    if (!f?.geometry) return;
    const b = new maplibregl.LngLatBounds();
    extendBounds(b, f.geometry);
    if (!b.isEmpty()) map.fitBounds(b, { padding: 80, maxZoom: 17, duration: 600 });
  }

  // ---- Choropleth metric switcher + legend ----------------------------------
  const switchEl = document.getElementById('metric-switch') as HTMLElement;
  const legendTitle = document.getElementById('legend-title') as HTMLElement;
  const legendBody = document.getElementById('legend-body') as HTMLElement;
  const legendNote = document.getElementById('legend-note') as HTMLElement;
  const rangePicker = document.getElementById('range-picker') as HTMLElement;
  const rangeFrom = document.getElementById('range-from') as HTMLSelectElement;
  const rangeTo = document.getElementById('range-to') as HTMLSelectElement;

  function renderSwitch(): void {
    switchEl.innerHTML = Object.entries(METRICS)
      .map(
        ([key, m]) =>
          `<button type="button" data-metric="${key}" class="${key === activeMetric ? 'active' : ''}" ` +
          `aria-pressed="${key === activeMetric}">${escapeHtml(m.label)}</button>`,
      )
      .join('');
    switchEl.querySelectorAll('button').forEach((btn) =>
      btn.addEventListener('click', () => void setMetric(btn.dataset.metric as MetricKey)),
    );
  }

  // Length of the selected comparison window in years (≥1); drives the change
  // colour breaks so a single-GA year and a 14-year span both read with contrast.
  function changeWindow(): number {
    return Math.max(1, endYear - baselineYear);
  }

  const swatchLi = (color: string, label: string, liAttrs = ''): string =>
    `<li${liAttrs ? ` ${liAttrs}` : ''}><span class="swatch" style="background:${color}"></span>${escapeHtml(label)}</li>`;

  // ---- Use-type filter --------------------------------------------------------
  // Hidden display groups for the use-type metric. The legend rows double as
  // toggles; the resulting filter applies to every parcel layer (fill, line, 3d)
  // and is cleared whenever the metric switches away.
  const hiddenUseGroups = new Set<UseTypeGroupKey>();
  let useFilterApplied = false;

  function applyUseFilter(): void {
    const filter =
      activeMetric === 'use_type' ? useTypeFilterExpression(hiddenUseGroups) : null;
    // Clearing an already-clear filter is NOT a no-op in MapLibre (it reloads
    // the whole GeoJSON source) — skip it to keep plain metric switches on the
    // cheap paint-property path.
    if (filter === null && !useFilterApplied) return;
    useFilterApplied = filter !== null;
    for (const id of ['parcels-fill', 'parcels-line', 'parcels-3d']) {
      if (map.getLayer(id)) map.setFilter(id, filter);
    }
  }

  // Legend rows as hide/show toggles for the use-type metric.
  function renderUseLegend(): void {
    legendBody.innerHTML = USE_TYPE_GROUPS.map((g) => {
      const off = hiddenUseGroups.has(g.key);
      return swatchLi(
        g.color,
        g.label,
        `class="use-toggle${off ? ' off' : ''}" data-group="${g.key}" role="button" ` +
          `tabindex="0" aria-pressed="${!off}"`,
      );
    }).join('');
    legendBody.querySelectorAll<HTMLLIElement>('li.use-toggle').forEach((li) => {
      const toggle = (): void => {
        const key = li.dataset.group as UseTypeGroupKey;
        if (hiddenUseGroups.has(key)) hiddenUseGroups.delete(key);
        else hiddenUseGroups.add(key);
        applyUseFilter();
        renderUseLegend();
      };
      li.addEventListener('click', toggle);
      li.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          toggle();
        }
      });
    });
  }

  function renderLegend(): void {
    const m = METRICS[activeMetric];
    legendTitle.textContent = m.label;
    if (activeMetric === 'recent_change') {
      const labels = changeLegend(changeStops(changeWindow()));
      legendBody.innerHTML =
        labels.map((label, i) => swatchLi(RECENT_CHANGE_COLORS[i]!, label)).join('') +
        swatchLi(NO_DATA_COLOR, 'no data');
      rangePicker.hidden = false;
      legendNote.textContent = marByYear
        ? `Median per-unit MAR change, ${baselineYear} → ${endYear}.`
        : 'Loading…';
    } else if (activeMetric === 'use_type') {
      renderUseLegend();
      rangePicker.hidden = true;
      legendNote.textContent = 'County assessor use class. Click a class to hide/show it.';
    } else {
      legendBody.innerHTML = m.legend.map((label, i) => swatchLi(m.colors[i]!, label)).join('');
      rangePicker.hidden = true;
      legendNote.textContent = '';
    }
  }

  // Paint the change choropleth with breaks scaled to the current window. Both the
  // value (range_change_pct) and the colour breaks depend on the window, so this
  // runs whenever the years change — not just on metric switch.
  function recolorChange(): void {
    const expr = recentChangeColorExpression(changeStops(changeWindow()));
    map.setPaintProperty('parcels-fill', 'fill-color', expr);
    if (map.getLayer('parcels-3d'))
      map.setPaintProperty('parcels-3d', 'fill-extrusion-color', expr);
  }

  // ---- Configurable MAR-change choropleth -----------------------------------
  // Load the per-parcel median-MAR-by-year matrix once (lazily, on first use of
  // the change metric), seed the default comparison window, and colour the map.
  async function ensureMarByYear(): Promise<void> {
    if (marByYear) return;
    if (!marByYearPromise) {
      marByYearPromise = (async () => {
        const r = await fetch(dataUrl('mar_by_year.json'));
        if (!r.ok) throw new Error(`Failed to load mar_by_year.json: ${r.status}`);
        marByYear = (await r.json()) as MarByYear;
        const yrs = marByYear.years;
        endYear = yrs[yrs.length - 1]!;
        baselineYear = Math.max(yrs[0]!, Math.min(RECENT_CHANGE_DEFAULT_BASELINE, endYear - 1));
        renderRangePicker();
        applyRangeChange();
      })();
    }
    await marByYearPromise;
  }

  // Median of a numeric list (unsorted input; returns 0 for empty — callers guard).
  function medianOf(values: number[]): number {
    const s = [...values].sort((a, b) => a - b);
    const m = Math.floor(s.length / 2);
    return s.length % 2 ? s[m]! : (s[m - 1]! + s[m]!) / 2;
  }

  // Recompute each parcel's change for the selected window — the MEDIAN of its
  // units' own % moves, over units controlled (MAR > 0) in BOTH the baseline and
  // end year — and push it back into the source. promoteId keeps feature ids
  // stable, so hover/select feature-state survives the setData.
  function applyRangeChange(): void {
    if (!parcelsGeojson || !marByYear) return;
    const bi = marByYear.years.indexOf(baselineYear);
    const ei = marByYear.years.indexOf(endYear);
    for (const f of parcelsGeojson.features) {
      const props = f.properties as ParcelProperties | null;
      if (!props) continue;
      const vectors = bi >= 0 && ei >= 0 ? marByYear.parcels[String(props.apn)] : undefined;
      let pct: number | null = null;
      if (vectors) {
        const moves: number[] = [];
        for (const v of vectors) {
          const b = v[bi] ?? 0;
          const e = v[ei] ?? 0;
          if (b > 0 && e > 0) moves.push(((e - b) / b) * 100);
        }
        if (moves.length) pct = medianOf(moves);
      }
      props.range_has_data = pct == null ? 0 : 1;
      props.range_change_pct = pct == null ? 0 : Number(pct.toFixed(1));
    }
    const src = map.getSource('parcels') as maplibregl.GeoJSONSource | undefined;
    src?.setData(parcelsGeojson);
  }

  // Populate the from/to year dropdowns to mirror the current selection.
  function renderRangePicker(): void {
    if (!marByYear) return;
    const fill = (sel: HTMLSelectElement, opts: number[], chosen: number): void => {
      sel.innerHTML = opts
        .map((y) => `<option value="${y}"${y === chosen ? ' selected' : ''}>${y}</option>`)
        .join('');
    };
    // The baseline can't be the last year, nor the end the first — so every pick
    // leaves a valid window on the other side.
    fill(rangeFrom, marByYear.years.slice(0, -1), baselineYear);
    fill(rangeTo, marByYear.years.slice(1), endYear);
  }

  rangeFrom.addEventListener('change', () => {
    if (!marByYear) return;
    baselineYear = Number(rangeFrom.value);
    // Keep the window ordered (baseline strictly before end).
    if (baselineYear >= endYear) {
      endYear = Math.min(marByYear.years[marByYear.years.length - 1]!, baselineYear + 1);
    }
    renderRangePicker();
    applyRangeChange();
    recolorChange();
    renderLegend();
  });
  rangeTo.addEventListener('change', () => {
    if (!marByYear) return;
    endYear = Number(rangeTo.value);
    if (endYear <= baselineYear) {
      baselineYear = Math.max(marByYear.years[0]!, endYear - 1);
    }
    renderRangePicker();
    applyRangeChange();
    recolorChange();
    renderLegend();
  });

  async function setMetric(key: MetricKey): Promise<void> {
    if (key === activeMetric || !(key in METRICS)) return;
    activeMetric = key;
    if (key === 'recent_change') {
      await ensureMarByYear();
      recolorChange();
    } else {
      const colorExpr = colorExpressionFor(key);
      map.setPaintProperty('parcels-fill', 'fill-color', colorExpr);
      if (map.getLayer('parcels-3d'))
        map.setPaintProperty('parcels-3d', 'fill-extrusion-color', colorExpr);
    }
    // Applies the use filter while on use_type; clears it when switching away.
    applyUseFilter();
    renderSwitch();
    renderLegend();
  }

  // ---- Search (address / APN) -----------------------------------------------
  type SearchEntry = { apn: string; label: string; addr: string[] };
  const searchInput = document.getElementById('parcel-search') as HTMLInputElement | null;
  const searchResults = document.getElementById('search-results') as HTMLElement | null;
  let searchData: SearchEntry[] | null = null;
  let searchLoading = false;
  let lastResults: SearchEntry[] = [];

  async function ensureSearchData(): Promise<void> {
    if (searchData || searchLoading) return;
    searchLoading = true;
    try {
      const r = await fetch(dataUrl('search.json'));
      if (r.ok) searchData = (await r.json()) as SearchEntry[];
    } finally {
      searchLoading = false;
    }
  }

  function runSearch(q: string): SearchEntry[] {
    const query = q.trim().toLowerCase();
    if (!query || !searchData) return [];
    const digits = query.replace(/\D/g, '');
    const out: SearchEntry[] = [];
    for (const e of searchData) {
      const byApn = digits.length >= 3 && e.apn.startsWith(digits);
      const byAddr = e.addr.some((a) => a.toLowerCase().includes(query));
      if (byApn || byAddr) out.push(e);
      if (out.length >= 8) break;
    }
    return out;
  }

  function renderResults(items: SearchEntry[]): void {
    if (!searchResults) return;
    if (!items.length) {
      searchResults.hidden = true;
      searchResults.innerHTML = '';
      return;
    }
    searchResults.innerHTML = items
      .map(
        (e) =>
          `<li><button type="button" data-apn="${e.apn}">` +
          `${escapeHtml(e.label || 'APN ' + e.apn)}<span class="r-apn">${escapeHtml(e.apn)}</span>` +
          `</button></li>`,
      )
      .join('');
    searchResults.hidden = false;
    searchResults
      .querySelectorAll('button')
      .forEach((b) => b.addEventListener('click', () => chooseResult(b.dataset.apn ?? '')));
  }

  function chooseResult(apn: string): void {
    if (!apn) return;
    if (searchInput) searchInput.value = '';
    renderResults([]);
    flyToParcel(apn);
    void openParcel(apn);
  }

  if (searchInput && searchResults) {
    let debounce: number | undefined;
    searchInput.addEventListener('focus', () => void ensureSearchData());
    searchInput.addEventListener('input', () => {
      window.clearTimeout(debounce);
      debounce = window.setTimeout(async () => {
        await ensureSearchData();
        lastResults = runSearch(searchInput.value);
        renderResults(lastResults);
      }, 120);
    });
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && lastResults[0]) {
        e.preventDefault();
        chooseResult(lastResults[0].apn);
      } else if (e.key === 'Escape') {
        renderResults([]);
      }
    });
    document.addEventListener('click', (e) => {
      if (!searchResults.hidden && !(e.target as Element).closest('.search')) renderResults([]);
    });
  }

  function setSelected(apn: string | null): void {
    if (selected) map.setFeatureState({ source: 'parcels', id: selected }, { selected: false });
    selected = apn;
    if (apn) map.setFeatureState({ source: 'parcels', id: apn }, { selected: true });
  }

  function closePanel(): void {
    panel.hidden = true;
    setSelected(null);
    clearHash();
  }

  async function openParcel(apn: string): Promise<void> {
    setSelected(apn);
    panel.hidden = false;
    panelBody.innerHTML = '<p class="detail-loading">Loading…</p>';
    try {
      let detail = detailCache.get(apn);
      if (!detail) {
        const res = await fetch(dataUrl(`parcels/${apn}.json`));
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        detail = (await res.json()) as ParcelDetail;
        detailCache.set(apn, detail);
      }
      // Guard against a slower fetch resolving after another parcel was selected.
      if (selected !== apn) return;
      panelBody.innerHTML = renderParcelDetail(detail);
      hydrateChart(detail);
      setHash(apn);
    } catch (err) {
      panelBody.innerHTML = `<p class="detail-error">Couldn't load parcel ${apn}: ${String(err)}</p>`;
    }
  }

  // Lazily render the MAR-history chart (Plot/d3 loaded on demand, not upfront).
  function hydrateChart(detail: ParcelDetail): void {
    const host = panelBody.querySelector<HTMLElement>('.mar-chart');
    if (!host || detail.mar_history.length < 2) return;
    void import('../lib/chart').then(({ marHistoryChart }) => {
      if (selected !== detail.apn) return; // panel moved on while loading
      host.replaceChildren(marHistoryChart(detail.mar_history, host.clientWidth || 360));
    });
  }

  closeBtn.addEventListener('click', closePanel);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !panel.hidden) closePanel();
  });
</script>

