---
import 'maplibre-gl/dist/maplibre-gl.css';
import { METRICS } from '../config';

// Legend is rendered statically from the metric config (no client JS needed).
const metric = METRICS.unit_count;
const legendBins = metric.legend.map((label, i) => ({ label, color: metric.colors[i] }));
---

<div id="map" role="application" aria-label="Map of Santa Monica rent-controlled parcels"></div>

<div class="legend" aria-hidden="false">
  <p class="legend-title">{metric.label}</p>
  <ul>
    {
      legendBins.map((bin) => (
        <li>
          <span class="swatch" style={`background:${bin.color}`}></span>
          {bin.label}
        </li>
      ))
    }
  </ul>
</div>

<aside id="detail-panel" class="detail-panel" aria-label="Parcel detail" hidden>
  <button id="detail-close" class="detail-close" type="button" aria-label="Close parcel detail">
    ✕
  </button>
  <div id="detail-body" class="detail-body"></div>
</aside>

<script>
  import maplibregl from 'maplibre-gl';
  import {
    BASEMAP_STYLE,
    INITIAL_CENTER,
    INITIAL_ZOOM,
    PARCEL_ATTRIBUTION,
    METRICS,
    stepColorExpression,
    dataUrl,
  } from '../config';
  import { formatCount, formatMarCents } from '../lib/format';
  import { renderParcelDetail } from '../lib/detail';
  import type { ParcelProperties, ParcelDetail } from '../lib/types';

  const metric = METRICS.unit_count;

  const map = new maplibregl.Map({
    container: 'map',
    style: BASEMAP_STYLE,
    center: INITIAL_CENTER,
    zoom: INITIAL_ZOOM,
    attributionControl: false,
  });
  map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');
  map.addControl(
    new maplibregl.AttributionControl({ compact: false, customAttribution: PARCEL_ATTRIBUTION }),
    'bottom-right',
  );

  const escapeHtml = (s: string): string =>
    s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]!);

  function tooltipHtml(p: ParcelProperties): string {
    const controlled = `${formatCount(p.controlled_count)} controlled`;
    const exempt = p.exempt_count > 0 ? ` · ${formatCount(p.exempt_count)} exempt` : '';
    return (
      `<strong>${escapeHtml(p.label_address)}</strong>` +
      `<span class="apn">APN ${escapeHtml(p.apn)}</span>` +
      `<span class="row">${formatCount(p.unit_count)} units — ${controlled}${exempt}</span>` +
      `<span class="row">Median MAR ${formatMarCents(p.median_mar_cents)}</span>`
    );
  }

  // Extend a bounds object with every coordinate in a (Multi)Polygon geometry.
  function extendBounds(b: maplibregl.LngLatBounds, geom: GeoJSON.Geometry): void {
    if (geom.type === 'Polygon') {
      for (const ring of geom.coordinates)
        for (const c of ring) b.extend(c as [number, number]);
    } else if (geom.type === 'MultiPolygon') {
      for (const poly of geom.coordinates)
        for (const ring of poly) for (const c of ring) b.extend(c as [number, number]);
    }
  }

  map.on('load', async () => {
    const res = await fetch(dataUrl('parcels.geojson'));
    if (!res.ok) throw new Error(`Failed to load parcels.geojson: ${res.status}`);
    const geojson = (await res.json()) as GeoJSON.FeatureCollection;

    map.addSource('parcels', { type: 'geojson', data: geojson, promoteId: 'apn' });

    map.addLayer({
      id: 'parcels-fill',
      type: 'fill',
      source: 'parcels',
      paint: {
        'fill-color': stepColorExpression(metric),
        'fill-opacity': ['case', ['boolean', ['feature-state', 'hover'], false], 0.95, 0.72],
      },
    });
    map.addLayer({
      id: 'parcels-line',
      type: 'line',
      source: 'parcels',
      paint: {
        'line-color': [
          'case',
          ['boolean', ['feature-state', 'selected'], false],
          '#b91c1c',
          '#2b3b4e',
        ],
        'line-width': [
          'case',
          ['boolean', ['feature-state', 'selected'], false],
          2.6,
          ['boolean', ['feature-state', 'hover'], false],
          1.8,
          0.3,
        ],
        'line-opacity': 0.6,
      },
    });

    // Frame the data + index features by APN for deep-link fly-to.
    const bounds = new maplibregl.LngLatBounds();
    for (const f of geojson.features) {
      if (!f.geometry) continue;
      extendBounds(bounds, f.geometry);
      const apn = (f.properties as ParcelProperties | null)?.apn;
      if (apn) featureByApn.set(String(apn), f);
    }
    if (!bounds.isEmpty()) map.fitBounds(bounds, { padding: 24, animate: false });

    // Hover: highlight via feature-state + a follow-the-cursor tooltip.
    const popup = new maplibregl.Popup({
      closeButton: false,
      closeOnClick: false,
      className: 'parcel-tip',
      maxWidth: '260px',
    });
    let hovered: string | null = null;

    map.on('mousemove', 'parcels-fill', (e) => {
      const f = e.features?.[0];
      if (!f) return;
      map.getCanvas().style.cursor = 'pointer';
      const id = String(f.id);
      if (hovered !== id) {
        if (hovered) map.setFeatureState({ source: 'parcels', id: hovered }, { hover: false });
        hovered = id;
        map.setFeatureState({ source: 'parcels', id }, { hover: true });
      }
      popup.setLngLat(e.lngLat).setHTML(tooltipHtml(f.properties as ParcelProperties)).addTo(map);
    });
    map.on('mouseleave', 'parcels-fill', () => {
      map.getCanvas().style.cursor = '';
      if (hovered) map.setFeatureState({ source: 'parcels', id: hovered }, { hover: false });
      hovered = null;
      popup.remove();
    });

    // Click: lazy-load the per-APN detail and open the side panel.
    map.on('click', 'parcels-fill', (e) => {
      const f = e.features?.[0];
      if (!f) return;
      void openParcel(String(f.id));
    });

    // Deep link: open + fly to a parcel named in the URL hash (#apn=...).
    const initial = apnFromHash();
    if (initial && featureByApn.has(initial)) {
      flyToParcel(initial);
      void openParcel(initial);
    }
  });

  // ---- Detail panel ---------------------------------------------------------
  const panel = document.getElementById('detail-panel') as HTMLElement;
  const panelBody = document.getElementById('detail-body') as HTMLElement;
  const closeBtn = document.getElementById('detail-close') as HTMLButtonElement;
  let selected: string | null = null;
  const detailCache = new Map<string, ParcelDetail>();
  const featureByApn = new Map<string, GeoJSON.Feature>();

  // ---- Deep link (#apn=...) -------------------------------------------------
  function apnFromHash(): string | null {
    const m = /(?:^|[#&])apn=(\d+)/.exec(location.hash);
    return m ? m[1]! : null;
  }
  function setHash(apn: string): void {
    history.replaceState(null, '', `#apn=${apn}`);
  }
  function clearHash(): void {
    history.replaceState(null, '', location.pathname + location.search);
  }

  function flyToParcel(apn: string): void {
    const f = featureByApn.get(apn);
    if (!f?.geometry) return;
    const b = new maplibregl.LngLatBounds();
    extendBounds(b, f.geometry);
    if (!b.isEmpty()) map.fitBounds(b, { padding: 80, maxZoom: 17, duration: 600 });
  }

  function setSelected(apn: string | null): void {
    if (selected) map.setFeatureState({ source: 'parcels', id: selected }, { selected: false });
    selected = apn;
    if (apn) map.setFeatureState({ source: 'parcels', id: apn }, { selected: true });
  }

  function closePanel(): void {
    panel.hidden = true;
    setSelected(null);
    clearHash();
  }

  async function openParcel(apn: string): Promise<void> {
    setSelected(apn);
    panel.hidden = false;
    panelBody.innerHTML = '<p class="detail-loading">Loading…</p>';
    try {
      let detail = detailCache.get(apn);
      if (!detail) {
        const res = await fetch(dataUrl(`parcels/${apn}.json`));
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        detail = (await res.json()) as ParcelDetail;
        detailCache.set(apn, detail);
      }
      // Guard against a slower fetch resolving after another parcel was selected.
      if (selected !== apn) return;
      panelBody.innerHTML = renderParcelDetail(detail);
      hydrateChart(detail);
      setHash(apn);
    } catch (err) {
      panelBody.innerHTML = `<p class="detail-error">Couldn't load parcel ${apn}: ${String(err)}</p>`;
    }
  }

  // Lazily render the MAR-history chart (Plot/d3 loaded on demand, not upfront).
  function hydrateChart(detail: ParcelDetail): void {
    const host = panelBody.querySelector<HTMLElement>('.mar-chart');
    if (!host || detail.mar_history.length < 2) return;
    void import('../lib/chart').then(({ marHistoryChart }) => {
      if (selected !== detail.apn) return; // panel moved on while loading
      host.replaceChildren(marHistoryChart(detail.mar_history, host.clientWidth || 360));
    });
  }

  closeBtn.addEventListener('click', closePanel);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !panel.hidden) closePanel();
  });
</script>

<style>
  #map {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .legend {
    position: absolute;
    left: 1rem;
    bottom: 1.75rem;
    z-index: 2;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(6px);
    border: 1px solid color-mix(in srgb, var(--muted) 35%, transparent);
    border-radius: 0.5rem;
    padding: 0.6rem 0.75rem;
    font-size: 0.8rem;
    box-shadow: 0 2px 10px rgb(0 0 0 / 0.12);
  }
  .legend-title {
    margin: 0 0 0.4rem;
    font-weight: 600;
  }
  .legend ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.2rem;
  }
  .legend li {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    white-space: nowrap;
  }
  .swatch {
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 2px;
    border: 1px solid rgb(0 0 0 / 0.2);
    flex: none;
  }

  .detail-panel {
    position: absolute;
    top: 0;
    right: 0;
    z-index: 4;
    width: min(420px, 92vw);
    height: 100%;
    overflow-y: auto;
    background: var(--bg);
    border-left: 1px solid color-mix(in srgb, var(--muted) 35%, transparent);
    box-shadow: -4px 0 20px rgb(0 0 0 / 0.14);
    padding: 1rem 1.1rem 2rem;
  }
  .detail-panel[hidden] {
    display: none;
  }
  .detail-close {
    position: sticky;
    top: 0;
    float: right;
    margin: -0.25rem -0.25rem 0 0.5rem;
    width: 2rem;
    height: 2rem;
    border: none;
    border-radius: 50%;
    background: color-mix(in srgb, var(--muted) 18%, transparent);
    color: var(--fg);
    font-size: 0.85rem;
    cursor: pointer;
  }
  .detail-close:hover {
    background: color-mix(in srgb, var(--muted) 32%, transparent);
  }
</style>

<style is:global>
  /* Tooltip skin (Popup content lives outside the component's scoped styles). */
  .parcel-tip .maplibregl-popup-content {
    padding: 0.55rem 0.7rem;
    border-radius: 0.5rem;
    font-size: 0.82rem;
    line-height: 1.35;
    box-shadow: 0 3px 14px rgb(0 0 0 / 0.18);
  }
  .parcel-tip strong {
    display: block;
  }
  .parcel-tip .apn {
    display: block;
    color: #6b7280;
    font-size: 0.72rem;
    margin-bottom: 0.25rem;
  }
  .parcel-tip .row {
    display: block;
  }

  /* Detail panel content (rendered via innerHTML → outside scoped styles). */
  .detail-body .muted {
    color: var(--muted);
  }
  .detail-head {
    margin-bottom: 0.9rem;
  }
  .detail-head .single-address,
  .detail-head .addresses > summary {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0;
  }
  .detail-head .addresses {
    margin: 0;
  }
  .detail-head .addresses > summary {
    cursor: pointer;
  }
  .detail-head .addresses ul {
    margin: 0.35rem 0 0;
    padding-left: 1.1rem;
    font-size: 0.85rem;
  }
  .detail-head .apn {
    margin: 0.15rem 0 0;
    font-size: 0.74rem;
  }
  .detail-head .statline {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
  }
  .detail-loading,
  .detail-error {
    color: var(--muted);
    font-size: 0.9rem;
  }
  table.units {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
  }
  table.units th,
  table.units td {
    text-align: left;
    padding: 0.34rem 0.4rem;
    border-bottom: 1px solid color-mix(in srgb, var(--muted) 22%, transparent);
  }
  table.units th {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  table.units .num {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  table.units tbody tr:hover {
    background: color-mix(in srgb, var(--accent) 7%, transparent);
  }
  .badge {
    display: inline-block;
    padding: 0.05rem 0.4rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: capitalize;
  }
  .badge.status-controlled {
    background: color-mix(in srgb, #16a34a 18%, transparent);
    color: #15803d;
  }
  .badge.status-exempt {
    background: color-mix(in srgb, var(--muted) 22%, transparent);
    color: var(--muted);
  }

  .detail-section {
    margin-top: 1.4rem;
  }
  .detail-section h2 {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    margin: 0 0 0.5rem;
  }
  .mar-chart {
    overflow-x: auto;
  }
  ul.changes,
  ul.exits {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  ul.changes li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.05rem 0.6rem;
    font-size: 0.82rem;
    padding-bottom: 0.45rem;
    border-bottom: 1px solid color-mix(in srgb, var(--muted) 18%, transparent);
  }
  ul.changes .when {
    grid-row: 1 / span 2;
    font-variant-numeric: tabular-nums;
    color: var(--muted);
    font-size: 0.76rem;
    align-self: start;
  }
  ul.changes .why {
    font-size: 0.74rem;
    color: var(--muted);
  }
  .delta {
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }
  .delta.up {
    color: #b91c1c;
  }
  .delta.down {
    color: #15803d;
  }
  ul.exits li {
    font-size: 0.82rem;
  }
  .exit-note {
    font-size: 0.78rem;
    margin: 0 0 0.5rem;
  }
</style>
