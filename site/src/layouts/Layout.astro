---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Santa Monica Rent-Control Registry',
  description = 'A public map of Santa Monica rent-controlled units and their Maximum Allowable Rent.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --bg: #fbfbfa;
    --fg: #1a1a1a;
    --muted: #666;
    --accent: #2563eb;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #16181d;
      --fg: #e8e8e8;
      --muted: #9aa0aa;
      --accent: #6ea8ff;
    }
  }
  * {
    box-sizing: border-box;
  }
  html,
  body {
    margin: 0;
    padding: 0;
  }
  body {
    background: var(--bg);
    color: var(--fg);
    font-family:
      system-ui,
      -apple-system,
      'Segoe UI',
      Roboto,
      sans-serif;
    line-height: 1.55;
  }
</style>
